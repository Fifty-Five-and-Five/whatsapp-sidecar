# Bearer token earl-tasks uses to call this sidecar. Generate with: openssl rand -hex 32
SIDECAR_TOKEN=

# The single WhatsApp group JID this sidecar is scoped to. Looks like 1203...@g.us
# Leave blank for first boot - check logs after sending a message into the target group
# to find its JID, then set this and restart.
WHATSAPP_GROUP_JID=

# Server port
PORT=3030

# Pino log level
LOG_LEVEL=info
